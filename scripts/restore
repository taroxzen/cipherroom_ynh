#!/bin/bash
source /usr/share/yunohost/helpers

set -e

app=$YNH_APP_INSTANCE_NAME

# 1. Restore directories
ynh_restore_file "$install_dir"
ynh_restore_file "$data_dir"

# 2. Setup permissions for install directory
chown -R "$app:www-data" "$install_dir"
chmod -R 755 "$install_dir"

# Regenerate config.php just to be safe
cat <<EOF > "$install_dir/config.php"
<?php
\$CUSTOM_DB_FILE = '$data_dir/chat.db';
EOF
chown "$app:www-data" "$install_dir/config.php"
chmod 644 "$install_dir/config.php"

# 3. Setup permissions for data directory and database
chown -R "$app:www-data" "$data_dir"
chmod 770 "$data_dir"

if [ -f "$data_dir/chat.db" ]; then
    chown "$app:www-data" "$data_dir/chat.db"
    chmod 660 "$data_dir/chat.db"
fi

# 4. Integrate configurations
ynh_add_nginx_config
ynh_add_fpm_config

